<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RecipeBook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.RecipeBook" parent="Base.Theme.RecipeBook">
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="ProfileImageCircle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="AuthInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>

        <item name="boxStrokeColor">#9A8F87</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2.5dp</item>

        <item name="boxBackgroundColor">#FFFDFC</item>

        <item name="hintTextColor">#8A817C</item>
        <item name="android:textColorHint">#8A817C</item>

    </style>

    <style name="AuthTitleText">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/assistant_bold</item>
        <item name="android:textColor">#2D2D2D</item>
    </style>

    <style name="AuthSubtitleText">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/assistant_regular</item>
        <item name="android:textColor">#7A7A7A</item>
    </style>

    <style name="AuthInputText">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">@font/assistant_semibold</item>
        <item name="android:textColor">#1C1C1C</item>
    </style>

    <style name="AuthButtonText">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/assistant_semibold</item>
    </style>

</resources>