<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.recipebook.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_profileFragment"
            app:destination="@id/profileFragment" />

        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_loginFragment_to_completeProfileFragment"
            app:destination="@id/completeProfileFragment" />

    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.recipebook.ui.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_registerFragment_to_completeProfileFragment"
            app:destination="@id/completeProfileFragment" />

    </fragment>

    <fragment
        android:id="@+id/completeProfileFragment"
        android:name="com.example.recipebook.ui.CompleteProfileFragment"
        android:label="Complete Profile"
        tools:layout="@layout/fragment_complete_profile">

        <argument
            android:name="fullName"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_completeProfileFragment_to_profileFragment"
            app:destination="@id/profileFragment" />

    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.recipebook.ui.RecipeBooksFragment"
        android:label="Recipe Books"
        tools:layout="@layout/fragment_recipe_books">

        <action
            android:id="@+id/action_homeFragment_to_recipeDetailsFragment"
            app:destination="@id/recipeDetailsFragment" />

        <action
            android:id="@+id/action_homeFragment_to_addRecipeFragment"
            app:destination="@id/addRecipeFragment" />

        <action
            android:id="@+id/action_homeFragment_to_bookRecipesFragment"
            app:destination="@id/bookRecipesFragment" />

    </fragment>

    <fragment
        android:id="@+id/recipeDetailsFragment"
        android:name="com.example.recipebook.ui.RecipeDetailsFragment"
        android:label="Recipe Details"
        tools:layout="@layout/fragment_recipe_details">

        <argument
            android:name="recipe"
            app:argType="com.example.recipebook.model.Recipe" />

        <action
            android:id="@+id/action_recipeDetailsFragment_to_addRecipeFragment"
            app:destination="@id/addRecipeFragment" />

    </fragment>

    <fragment
        android:id="@+id/addRecipeFragment"
        android:name="com.example.recipebook.ui.AddRecipeFragment"
        android:label="Add Recipe"
        tools:layout="@layout/fragment_add_recipe">

        <action
            android:id="@+id/action_addRecipeFragment_to_bookRecipesFragment"
            app:destination="@id/bookRecipesFragment" />

    </fragment>

    <fragment
        android:id="@+id/bookRecipesFragment"
        android:name="com.example.recipebook.ui.BookRecipesFragment"
        android:label="Book Recipes"
        tools:layout="@layout/fragment_book_recipes">

        <argument
            android:name="bookId"
            app:argType="integer" />

        <argument
            android:name="bookTitle"
            app:argType="string" />

        <action
            android:id="@+id/action_bookRecipesFragment_to_addRecipeFragment"
            app:destination="@id/addRecipeFragment" />

        <action
            android:id="@+id/action_bookRecipesFragment_to_recipeDetailsFragment"
            app:destination="@id/recipeDetailsFragment" />

    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.recipebook.ui.ProfileFragment"
        android:label="Profile">

        <action
            android:id="@+id/action_profileFragment_to_homeFragment"
            app:destination="@id/homeFragment" />

        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/profileFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_profileFragment_to_bookRecipesFragment"
            app:destination="@id/bookRecipesFragment" />

        <action
            android:id="@+id/action_profileFragment_to_myRecipesFragment"
            app:destination="@id/myRecipesFragment" />

        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />


    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.recipebook.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.recipebook.ui.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/addNavbarFragment"
        android:name="com.example.recipebook.ui.AddNavbarFragment"
        android:label="AddNavbar"
        tools:layout="@layout/fragment_add_navbar">

        <action
            android:id="@+id/action_addNavbarFragment_to_addRecipeFragment"
            app:destination="@id/addRecipeFragment" />

        <action
            android:id="@+id/action_addNavbarFragment_to_addRecipeBookFragment"
            app:destination="@id/addRecipeBookFragment" />

        <action
            android:id="@+id/action_profileFragment_to_addNavbarFragment"
            app:destination="@id/addNavbarFragment" />

    </fragment>

    <fragment
        android:id="@+id/addRecipeBookFragment"
        android:name="com.example.recipebook.ui.AddRecipeBookFragment"
        android:label="Add Recipe Book"
        tools:layout="@layout/fragment_add_recipe_book" />

    <fragment
        android:id="@+id/myRecipesFragment"
        android:name="com.example.recipebook.ui.MyRecipesFragment"
        android:label="My Recipes"
        tools:layout="@layout/fragment_my_recipes">

        <action
            android:id="@+id/action_myRecipesFragment_to_addRecipeFragment"
            app:destination="@id/addRecipeFragment" />

        <action
            android:id="@+id/action_myRecipesFragment_to_recipeDetailsFragment"
            app:destination="@id/recipeDetailsFragment" />
    </fragment>

</navigation>