<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text=""
            android:backgroundTint="#89abf6"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Recipe Books"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#2D2D2D"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- create book-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_chip"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/headerCreate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Create new recipe book"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/arrowCreate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="16sp"
                    android:textColor="#89abf6"/>
            </LinearLayout>

            <!--content-->
            <LinearLayout
                android:id="@+id/contentCreate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etBookName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Book name"
                    android:padding="16dp"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_chip_small"
                    android:textColor="#2D2D2D"
                    android:lineSpacingExtra="4dp"/>

                <EditText
                    android:id="@+id/etBookDescription"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="Description"
                    android:padding="16dp"
                    android:textSize="14sp"
                    android:background="@drawable/bg_chip_small"
                    android:textColor="#2D2D2D"
                    android:gravity="top"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="4dp"/>

                <Spinner
                    android:id="@+id/spinnerPrivacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnCreateBook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Book"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#89abf6"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!--add recipe-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_chip">

            <LinearLayout
                android:id="@+id/headerAdd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Add recipe to book"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/arrowAdd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="16sp"
                    android:textColor="#89abf6"/>
            </LinearLayout>

            <!--content-->
            <LinearLayout
                android:id="@+id/contentAdd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/spinnerBooks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerRecipes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:id="@+id/btnAddRecipe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Recipe"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#89abf6"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>